config BOARD_CHLOROPLAST
    select SOC_NRF52840_QIAA if BOARD_CHLOROPLAST

    select SOC_NRF52840_QIAA if BOARD_CHLOROPLAST_NRF52840_ZMK
    select ZMK_BOARD_COMPAT if BOARD_CHLOROPLAST_NRF52840_ZMK
    imply RETAINED_MEM if BOARD_CHLOROPLAST_NRF52840_ZMK
    imply RETENTION if BOARD_CHLOROPLAST_NRF52840_ZMK
    imply RETENTION_BOOT_MODE if BOARD_CHLOROPLAST_NRF52840_ZMK
